# App
APP_ENV=development
LOG_LEVEL=INFO

# Where this service is reachable at (used for links in emails, redirects)
IDENTITY_URL=http://localhost:8001

# Where users land after registering / resetting password (product frontend)
POST_AUTH_REDIRECT_URL=http://localhost:5173

# CORS — comma-separated list of allowed product frontends
ALLOWED_FRONTENDS=http://localhost:5173,http://localhost:5174

# Session
SESSION_SECRET=dev-secret-change-me
# In production, set to .klaser.co.il so the cookie is readable by every product frontend
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_NAME=klaser_session

# Database
DATABASE_URL=postgresql+psycopg://localhost/klaser_identity

# Google OAuth (single client, one authorized redirect URI at /api/auth/google/callback)
GOOGLE_CLIENT_ID=

# Password / token config
BCRYPT_ROUNDS=12
REGISTRATION_TOKEN_TTL_DAYS=7
PASSWORD_RESET_TOKEN_TTL_HOURS=1

# Mail — Resend
RESEND_API_KEY=
MAIL_FROM_EMAIL=noreply@klaser.co.il
MAIL_FROM_NAME=Klaser

# Service tokens — comma-separated list of bearer tokens accepted at /api/service/*
# Each product backend gets its own token. Rotate one at a time by adding the new one, deploying, then removing the old.
SERVICE_TOKENS=
